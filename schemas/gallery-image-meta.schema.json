{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://galleree.dev/schemas/gallery-image-meta.schema.json",
  "title": "Galleree image metadata",
  "type": "object",
  "required": ["version", "id", "title", "tags"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "description": { "type": "string", "maxLength": 4000 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "location": { "type": "string", "maxLength": 120 },
    "capturedOn": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "capturedAt": { "type": "string", "format": "date-time" },
    "camera": { "type": "string", "maxLength": 120 },
    "lens": { "type": "string", "maxLength": 120 },
    "collectionSlug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "alt": { "type": "string", "maxLength": 500 },
    "hidden": { "type": "boolean" },
    "sortOrder": { "type": "number" },
    "copyright": { "type": "string", "maxLength": 200 },
    "uploadedAt": { "type": "string", "format": "date-time" }
  }
}
